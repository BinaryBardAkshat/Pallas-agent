# ============================================================
# Pallas Agent — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# ------ LLM Providers ----------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ------ Default Behavior -------------------------------------
PALLAS_PROVIDER=anthropic       # anthropic | google | openai | openrouter | ollama
PALLAS_MODEL=                   # Override default model for chosen provider
PALLAS_NO_APPROVAL=0            # Set to 1 to skip human-in-loop approval for tools
PALLAS_SANDBOX=local            # local | docker | ssh | modal

# ------ Gateway: Telegram ------------------------------------
TELEGRAM_BOT_TOKEN=

# ------ Gateway: Discord -------------------------------------
DISCORD_BOT_TOKEN=

# ------ Gateway: Slack ---------------------------------------
SLACK_BOT_TOKEN=

# ------ Gateway: WhatsApp (Twilio) ---------------------------
TWILIO_ACCOUNT_SID=
WHATSAPP_API_KEY=               # Twilio Auth Token
TWILIO_WHATSAPP_FROM=           # e.g. +14155238886

# ------ Gateway: Signal (signal-cli) -------------------------
SIGNAL_PHONE_NUMBER=            # Your registered Signal number e.g. +12025551234
SIGNAL_CLI_PATH=signal-cli      # Path to signal-cli binary

# ------ Gateway: Email (IMAP/SMTP) ---------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587                  # 465 for SSL, 587 for STARTTLS
EMAIL_USER=pallas@example.com
EMAIL_PASSWORD=
IMAP_HOST=imap.example.com      # Defaults to EMAIL_HOST if not set
EMAIL_POLL_INTERVAL=30          # Seconds between inbox checks

# ------ Gateway: Home Assistant ------------------------------
HA_URL=http://homeassistant.local:8123
HA_TOKEN=                       # Long-lived access token from HA profile
HA_WEBHOOK_PORT=8765            # Local port for receiving HA webhook POSTs

# ------ Sandbox Backends -------------------------------------
# Docker backend
DOCKER_IMAGE=python:3.11-slim
DOCKER_WORKSPACE=               # Defaults to current working directory

# SSH backend
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_rsa

# Modal backend
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
